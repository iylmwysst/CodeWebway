#!/bin/sh

set -- "$@"
args=

for arg in "$@"; do
  case "$arg" in
    --target=x86_64-unknown-linux-musl|--target=x86_64-linux-musl)
      ;;
    *)
      args="$args
$arg"
      ;;
  esac
done

set --
OLDIFS=$IFS
IFS='
'
for arg in $args; do
  set -- "$@" "$arg"
done
IFS=$OLDIFS

exec /usr/local/bin/zig cc -target x86_64-linux-musl "$@"
